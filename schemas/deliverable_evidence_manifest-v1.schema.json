{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mettleforgelab.example/schemas/deliverable_evidence_manifest-v1.schema.json",
  "title": "deliverable_evidence_manifest-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tenant_id",
    "deliverable_id",
    "pipeline_run_id",
    "bundle_id",
    "bundle_manifest_sha256",
    "bundle_sha256",
    "deliverable_record_sha256",
    "docx_sha256",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "const": "deliverable_evidence_manifest-v1"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "deliverable_id": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_run_id": {
      "type": "string",
      "minLength": 1
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "bundle_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "bundle_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "deliverable_record_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "docx_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "audit_chain": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "metrics": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object"
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "kid",
        "sig"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "minLength": 1
        },
        "kid": {
          "type": "string",
          "minLength": 1
        },
        "sig": {
          "type": "string",
          "minLength": 1
        },
        "key_ref": {
          "type": "string"
        }
      }
    },
    "download_receipts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "created_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "event_type": {
            "type": "string"
          },
          "detail": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    },
    "bundle_status": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "revoked_at": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
