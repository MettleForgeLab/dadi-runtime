{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mettleforgelab.example/schemas/render_docx_output-v1.schema.json",
  "title": "render_docx_output-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage",
    "results",
    "citations",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "render_docx_output-v1"
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "name",
        "schema_version"
      ],
      "properties": {
        "index": {
          "const": 6
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "const": "v1"
        }
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docx_sha256",
        "media_type"
      ],
      "properties": {
        "docx_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_sha256"
      ],
      "properties": {
        "input_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "prompt_bundle_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
