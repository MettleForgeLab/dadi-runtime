{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mettleforgelab.example/schemas/docpack-v1.schema.json",
  "title": "docpack-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "raw_sha256",
    "pages"
  ],
  "properties": {
    "schema_version": {
      "const": "docpack-v1"
    },
    "doc_id": {
      "type": "string",
      "minLength": 1
    },
    "raw_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "parse_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/page"
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attachment"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_sha256"
      ],
      "properties": {
        "raw_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "parse_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "parser_toolchain_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "bbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x0",
        "y0",
        "x1",
        "y1"
      ],
      "properties": {
        "x0": {
          "type": "number"
        },
        "y0": {
          "type": "number"
        },
        "x1": {
          "type": "number"
        },
        "y1": {
          "type": "number"
        }
      }
    },
    "docpack_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "block_id"
      ],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "block_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "table_grid": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rows"
      ],
      "properties": {
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "type"
      ],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "text",
            "table",
            "figure"
          ]
        },
        "text": {
          "type": "string"
        },
        "table": {
          "$ref": "#/$defs/table_grid"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "source_ref": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "text"
              }
            }
          },
          "then": {
            "required": [
              "text"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "table"
              }
            }
          },
          "then": {
            "required": [
              "table"
            ]
          }
        }
      ]
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_num",
        "blocks"
      ],
      "properties": {
        "page_num": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      }
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sha256",
        "media_type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
