{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mettleforgelab.example/schemas/stage03-output-v1.schema.json",
  "title": "stage03-output-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage",
    "results",
    "citations",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "stage03-output-v1"
    },
    "stage": {
      "$ref": "#/$defs/stage_meta"
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facts",
        "tables_normalized",
        "open_items"
      ],
      "properties": {
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact"
          }
        },
        "tables_normalized": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/normalized_table"
          }
        },
        "open_items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "item",
              "docpack_ref"
            ],
            "properties": {
              "item": {
                "type": "string",
                "minLength": 1
              },
              "docpack_ref": {
                "$ref": "#/$defs/docpack_ref"
              }
            }
          }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/citation"
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "stage_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "name",
        "schema_version"
      ],
      "properties": {
        "index": {
          "const": 3
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "const": "v1"
        }
      }
    },
    "docpack_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "block_id"
      ],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "block_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docpack_ref"
      ],
      "properties": {
        "docpack_ref": {
          "$ref": "#/$defs/docpack_ref"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "value_number_currency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number"
      ],
      "properties": {
        "number": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "FY",
            "Q",
            "M",
            "OTHER"
          ]
        },
        "year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 3000
        },
        "quarter": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "label": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "FY"
              }
            }
          },
          "then": {
            "required": [
              "year"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "Q"
              }
            }
          },
          "then": {
            "required": [
              "year",
              "quarter"
            ]
          }
        }
      ]
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact_id",
        "field",
        "value",
        "confidence",
        "evidence"
      ],
      "properties": {
        "fact_id": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/value_number_currency"
        },
        "period": {
          "$ref": "#/$defs/period"
        },
        "unit": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "docpack_ref"
            ],
            "properties": {
              "docpack_ref": {
                "$ref": "#/$defs/docpack_ref"
              },
              "quote": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "normalized_table": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "table_id",
        "source",
        "schema",
        "rows"
      ],
      "properties": {
        "table_id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "docpack_ref"
          ],
          "properties": {
            "docpack_ref": {
              "$ref": "#/$defs/docpack_ref"
            }
          }
        },
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "columns"
          ],
          "properties": {
            "columns": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_sha256",
        "prompt_bundle_sha256"
      ],
      "properties": {
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "prompt_bundle_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
